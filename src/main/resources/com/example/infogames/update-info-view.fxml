            <Insets bottom="-5.0" left="-5.0" right="-5.0" top="-5.0" />
         </opaqueInsets>
      </TextField>
      <TextField fx:id="inputName" layoutX="176.0" layoutY="194.0" prefHeight="51.0" prefWidth="284.0" promptText="Имя" styleClass="text-field">
         <opaqueInsets>
            <Insets bottom="-5.0" left="-5.0" right="-5.0" top="-5.0" />
         </opaqueInsets>
      </TextField>
   </children>
</AnchorPane>
