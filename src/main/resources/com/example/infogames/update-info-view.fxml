            </ImageView>
         </graphic>
         <padding>
            <Insets bottom="-5.0" left="-5.0" right="-5.0" top="-5.0" />
         </padding>
      </Button>
      <Button fx:id="buttonBack" layoutX="35.0" layoutY="464.0" mnemonicParsing="false" prefHeight="60.0" prefWidth="66.0" styleClass="close-butten">
         <graphic>
            <ImageView fx:id="imageBack" fitHeight="62.0" fitWidth="65.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../../image/update-info/buttom-back.png" />
               </image>
            </ImageView>
         </graphic></Button>
      <Label alignment="CENTER" contentDisplay="CENTER" layoutX="283.0" layoutY="80.0" prefHeight="66.0" prefWidth="423.0" styleClass="name-text" text="Расскажи про себя" />
       <TextField fx:id="inputPassword" layoutX="581.0" layoutY="359.0" prefHeight="51.0" prefWidth="284.0" promptText="Пароль" styleClass="text-field">
           <opaqueInsets>
               <Insets bottom="-5.0" left="-5.0" right="-5.0" top="-5.0" />
           </opaqueInsets>
       </TextField>
      <TextField fx:id="inputSchool" layoutX="581.0" layoutY="276.0" prefHeight="51.0" prefWidth="284.0" promptText="Школа" styleClass="text-field">
         <opaqueInsets>
            <Insets bottom="-5.0" left="-5.0" right="-5.0" top="-5.0" />
         </opaqueInsets>
      </TextField>
      <TextField fx:id="inputSurname" layoutX="581.0" layoutY="195.0" prefHeight="51.0" prefWidth="284.0" promptText="Фамилия" styleClass="text-field">
