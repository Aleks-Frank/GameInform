<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="336.0" prefWidth="464.0" styleClass="transparent-pane" stylesheets="@../../../styles/word-windows-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.infogames.controllers.TaskInfoController">
    <children>
        <ImageView fitHeight="303.0" fitWidth="431.0" layoutY="33.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../../../image/task_info/fon.png" />
            </image>
        </ImageView>
        <Label fx:id="lavelNumber" alignment="CENTER" contentDisplay="CENTER" layoutX="96.0" layoutY="52.0" prefHeight="51.0" prefWidth="232.0" styleClass="name-text" text="Уровень №1" />
        <Label alignment="CENTER" layoutX="31.0" layoutY="153.0" prefHeight="76.0" prefWidth="362.0" styleClass="task-text" />
        <Label alignment="CENTER" layoutX="50.0" layoutY="276.0" prefHeight="32.0" prefWidth="323.0" styleClass="task-text" />
        <Label fx:id="lavelName" alignment="CENTER" layoutX="32.0" layoutY="145.0" prefHeight="51.0" prefWidth="356.0" styleClass="task-text" />
        <Button fx:id="buttonNext" contentDisplay="CENTER" layoutX="111.0" layoutY="276.0" mnemonicParsing="false" prefHeight="17.0" prefWidth="203.0" styleClass="next-butten" text="Продолжить">
            <graphic>
                <ImageView fx:id="imageNext" fitHeight="37.0" fitWidth="228.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../image/checker/bottun.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
      <Label fx:id="countStars" layoutX="205.0" layoutY="221.0" prefHeight="27.0" prefWidth="55.0" styleClass="count-stars" text="10" />
    </children>
</AnchorPane>
