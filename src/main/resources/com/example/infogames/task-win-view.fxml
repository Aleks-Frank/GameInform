<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="303.0" prefWidth="420.0" styleClass="transparent-pane" stylesheets="@../../../styles/word-windows-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.infogames.controllers.TaskWinController">
    <children>
        <ImageView fitHeight="303.0" fitWidth="431.0" layoutX="1.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../../../image/task_win/fon.png" />
            </image>
        </ImageView>
        <Label alignment="CENTER" contentDisplay="CENTER" layoutX="97.0" layoutY="25.0" prefHeight="27.0" prefWidth="232.0" styleClass="name-text" text="Молодец" />
        <Label alignment="CENTER" layoutX="32.0" layoutY="120.0" prefHeight="76.0" prefWidth="362.0" styleClass="task-text" />
        <Label alignment="CENTER" layoutX="51.0" layoutY="243.0" prefHeight="32.0" prefWidth="323.0" styleClass="task-text" />
        <Label alignment="CENTER" layoutX="33.0" layoutY="112.0" prefHeight="51.0" prefWidth="356.0" styleClass="name-text" text="Уровень пройден!" />
        <Button fx:id="buttonNext" contentDisplay="CENTER" layoutX="112.0" layoutY="243.0" mnemonicParsing="false" prefHeight="17.0" prefWidth="203.0" styleClass="next-butten" text="Продолжить">
            <graphic>
                <ImageView fx:id="imageNext" fitHeight="37.0" fitWidth="228.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../image/checker/bottun.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>
      <Label fx:id="countStars" alignment="CENTER" layoutX="191.0" layoutY="177.0" prefHeight="51.0" prefWidth="56.0" styleClass="count-stars" />
        <Button fx:id="buttonBack" layoutX="24.0" layoutY="235.0" mnemonicParsing="false" prefHeight="43.0" prefWidth="40.0" styleClass="back-butten">
            <graphic>
                <ImageView fx:id="imageBack" fitHeight="40.0" fitWidth="37.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../image/task_win/buttom-back.png" />
                    </image>
                </ImageView>
            </graphic>
            <padding>
                <Insets bottom="-5.0" left="-5.0" right="-5.0" top="-5.0" />
            </padding></Button>
    </children>
</AnchorPane>
